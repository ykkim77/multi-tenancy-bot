# API Keys (테스트용 더미 값)
EMBEDDING_API_KEY=sk-test-embedding-key
LLM_API_KEY=sk-test-llm-key

# Auth Mode
AUTH_MODE=DEV

# Embedding Worker 설정
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-ada-002
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=test-dept-knowledge
VECTOR_SIZE=1536
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# PostgreSQL 설정
POSTGRES_PASSWORD=outline-pass

# Redis 설정  
REDIS_PASSWORD=redis-pass